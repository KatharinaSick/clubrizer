{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "postgresql@17.2",
    "go-migrate@4.18.1",
    "go@1.23.4",
    "parallel@20241222"
  ],
  "env": {
    "GOPATH": "$HOME/go/",
    "PATH":   "$PATH:$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "echo '🤫 Preparing environment'",
      "export $(grep -v '^#' .env | xargs)",
      "export \"GOROOT=$(go env GOROOT)\"",
      "echo '🚀 Have fun coding!'"

    ],
    "scripts": {
      "initdb":    "initdb --username=postgres --pwfile=<(echo a-super-secure-password)",
      "startdb":   "todo",
      "stopdb":    "todo",
      "destroydb": "todo",
      "migratedb": "migrate -database ${DB_URL} -path database/migrations up",

      "backend":  "go run -C backend ./cmd/api-server/main.go",
      "frontend": "npm run dev --prefix frontend",
      "dev":      "parallel --line-buffer --tag ::: 'devbox run backend' 'devbox run frontend'",

      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
